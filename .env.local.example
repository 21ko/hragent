# Copy this file to .env.local and fill in your keys.
# The app runs fully on mock data when keys are absent, so you can demo
# the form -> agent -> results loop without any of these.

# --- Anthropic (the AI agent) ---
# Without this, lib/agent.ts returns a deterministic local shortlist.
ANTHROPIC_API_KEY=

# --- Supabase (candidate + mission database) ---
# Without these, lib/db.ts uses an in-memory store seeded from lib/seed-data.ts.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Twilio (WhatsApp + voice outreach) ---
# Without these, the agent simulates the call and logs the WhatsApp message.
# For the demo use the Twilio WhatsApp sandbox number, e.g. whatsapp:+14155238886
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Voice: a voice-capable Twilio number (the agent calls candidates from it first).
TWILIO_CALLER_NUMBER=
# Public base URL Twilio can reach for TwiML + callbacks (e.g. an ngrok https URL).
# Needed only for REAL outbound calls; the mock flow works without it.
PUBLIC_BASE_URL=
